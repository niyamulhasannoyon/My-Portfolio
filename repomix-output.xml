│  ├─ contact/page.tsx       # Lead-gen contact form
│  ├─ blog/
│  │  ├─ page.tsx            # Blog index
│  │  └─ [slug]/page.tsx     # Dynamic SSG case study (MDX + Article JSON-LD)
│  ├─ api/contact/route.ts   # Lead capture endpoint (wire to Resend/CRM)
