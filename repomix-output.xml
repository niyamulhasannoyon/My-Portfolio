        >
          {open ? <X className="h-4 w-4" /> : <Menu className="h-4 w-4" />}
        </button>
      </div>

      {/* Mobile Nav Overlay */}
      {open && (
        <>
          <div
            className="fixed inset-0 z-40 bg-zinc-950/60 backdrop-blur-sm md:hidden"
